export CROSSREF_PLUS_TOKEN="replace-with-crossref-plus-token"
# export CROSSREF_SOURCE_MODE="metadata_plus"
# For free/open-data-only mode use:
# export CROSSREF_SOURCE_MODE="skip"

# Optional: point the scripts at explicit binaries.
# export AWS_BIN="/usr/bin/aws"
# export CURL_BIN="/usr/bin/curl"
# export WGET_BIN="/usr/bin/wget"
# export GIT_BIN="/usr/bin/git"
# export PYTHON_BIN="/usr/bin/python3"

# Optional: let the collection scripts auto-load cluster modules.
export RAW_SNAPSHOT_AUTOLOAD_AWS_MODULE=1
export RAW_SNAPSHOT_AWS_MODULE="awscli/2.2.14"

# Optional: load additional modules before runtime checks.
# export RAW_SNAPSHOT_EXTRA_MODULES="java/jdk17 singularity/3.7.1"
