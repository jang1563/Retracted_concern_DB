#!/bin/bash
#SBATCH -J lsib-real-ingest
#SBATCH --cpus-per-task=2
#SBATCH --mem=32G
#SBATCH --time=24:00:00
#SBATCH -o __RUN_ROOT__/logs/real-ingest-%j.out

set -euo pipefail

RUN_ROOT="__RUN_ROOT__"
ART_RELEASE="$RUN_ROOT/artifacts/real_release"
ART_SITE="$RUN_ROOT/artifacts/real_site"
RAW_ROOT="$RUN_ROOT/raw/real_snapshot"
REPO_ROOT="$RUN_ROOT/repo"
SNAPSHOT_ID="real_snapshot_20260410"
CURRENT_STEP="bootstrap"
COMMON_SH="$REPO_ROOT/scripts/cayuga/common_job_env.sh"

mkdir -p "$ART_RELEASE" "$ART_SITE"
trap 'lsib_mark_failure "$ART_RELEASE" "$CURRENT_STEP"' ERR

source "$COMMON_SH"
lsib_activate_conda_env python.3.12.R.4.3.3

cd "$REPO_ROOT"
export PYTHONPATH=src

for required_dir in "$RAW_ROOT/openalex" "$RAW_ROOT/official_notices" "$RAW_ROOT/pubmed"; do
  lsib_require_nonempty_dir "$required_dir"
done

CURRENT_STEP="register_snapshot"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli \
  --release-dir "$ART_RELEASE" \
  register-snapshot \
  --snapshot-id "$SNAPSHOT_ID" \
  --raw-root "$RAW_ROOT" \
  --source-family openalex_notices

CURRENT_STEP="ingest_openalex"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli ingest-snapshot --snapshot-id "$SNAPSHOT_ID" --collector openalex_bulk

CURRENT_STEP="ingest_notices"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli ingest-snapshot --snapshot-id "$SNAPSHOT_ID" --collector local_notice_export

CURRENT_STEP="ingest_pubmed"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli ingest-snapshot --snapshot-id "$SNAPSHOT_ID" --collector pubmed_index

CURRENT_STEP="materialize_canonical"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli materialize-canonical --snapshot-id "$SNAPSHOT_ID"

CURRENT_STEP="validate_snapshot"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli --release-dir "$ART_RELEASE" validate-snapshot --snapshot-id "$SNAPSHOT_ID"

CURRENT_STEP="build_core"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli \
  --source-dir "$REPO_ROOT/data/normalized/$SNAPSHOT_ID/canonical" \
  --release-dir "$ART_RELEASE" \
  --site-dir "$ART_SITE" \
  build-core

CURRENT_STEP="build_splits"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli \
  --source-dir "$REPO_ROOT/data/normalized/$SNAPSHOT_ID/canonical" \
  --release-dir "$ART_RELEASE" \
  build-splits

CURRENT_STEP="audit_leakage"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli \
  --source-dir "$REPO_ROOT/data/normalized/$SNAPSHOT_ID/canonical" \
  --release-dir "$ART_RELEASE" \
  audit-leakage

CURRENT_STEP="train_task_a"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli \
  --source-dir "$REPO_ROOT/data/normalized/$SNAPSHOT_ID/canonical" \
  --release-dir "$ART_RELEASE" \
  train-task-a \
  --text-backend hashing

CURRENT_STEP="train_task_b"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli \
  --source-dir "$REPO_ROOT/data/normalized/$SNAPSHOT_ID/canonical" \
  --release-dir "$ART_RELEASE" \
  train-task-b

CURRENT_STEP="build_site"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli \
  --source-dir "$REPO_ROOT/data/normalized/$SNAPSHOT_ID/canonical" \
  --release-dir "$ART_RELEASE" \
  --site-dir "$ART_SITE" \
  build-site

CURRENT_STEP="build_report"
echo "$CURRENT_STEP" > "$ART_RELEASE/current_step.txt"
python3 -m life_science_integrity_benchmark.cli \
  --release-dir "$ART_RELEASE" \
  build-report

touch "$ART_RELEASE/COMPLETED"
